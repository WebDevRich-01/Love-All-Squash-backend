# Environment Configuration for Love All Squash Backend
# Copy this to .env and update with your actual values

# Database Configuration
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/love-all-squash?retryWrites=true&w=majority

# Server Configuration
PORT=3001

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGIN=https://your-new-frontend-url.netlify.app,http://localhost:3000,http://localhost:5173

# Node Environment
NODE_ENV=production

# Admin Authentication
# Generate with: node scripts/hashPassword.js <your-password>
# Leave blank to disable auth (not recommended in production)
ADMIN_PASSWORD_HASH=
